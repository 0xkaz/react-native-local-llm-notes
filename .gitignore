# Environment variables
.env
.env.local

# Logs
*.log

# Dependencies and caches
__pycache__/
*.pyc
node_modules/
.venv/
venv/
target/
dist/
build/

# Test coverage
coverage/

# Local model cache (served by `make serve-model` for fast dev downloads)
.model-cache/

# React Native / Metro
.metro-health-check*
*.jsbundle

# iOS (generated by `pod install` / Xcode)
ios/Pods/
ios/build/
ios/.xcode.env.local
**/xcuserdata/
vendor/bundle/

# Android (generated by Gradle / CMake native build cache)
android/.gradle/
android/build/
android/app/build/
android/app/.cxx/
android/local.properties
# Hexagon HTP libraries: copied from llama.rn into assets at build time, so they
# don't belong in the repo (avoids redistributing third-party prebuilt binaries).
android/app/src/main/assets/ggml-hexagon/
*.keystore
!debug.keystore

# OS
.DS_Store
