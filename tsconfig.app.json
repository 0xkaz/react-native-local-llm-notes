{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["react", "react-native", "jest", "node"],
    "noEmit": true,
    "declaration": false
  },
  "include": ["src/app", "src/native", "tests/app"]
}
